{% comment %}
  Editorial homepage hero with image-first layout and note blocks.
{% endcomment %}
{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  .section-{{ section.id }}-hero-height {
    min-height: {{ section.settings.hero_height | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }

    .section-{{ section.id }}-hero-height {
      min-height: {{ section.settings.hero_height }}px;
    }
  }
{%- endstyle -%}

<section class="editorial-hero section-{{ section.id }}-padding">
  <div class="page-width">
    <div class="editorial-hero__layout">
      <div class="editorial-hero__media section-{{ section.id }}-hero-height">
        {%- if section.settings.image != blank -%}
          {%- if section.settings.image_link != blank -%}
            <a class="editorial-hero__media-link" href="{{ section.settings.image_link }}">
          {%- endif -%}
          <div class="editorial-hero__image-wrap">
            {{
              section.settings.image
              | image_url: width: 2400
              | image_tag:
                class: 'editorial-hero__image',
                loading: 'eager',
                fetchpriority: 'high',
                widths: '600, 900, 1200, 1500, 1800, 2200, 2400',
                sizes: '(min-width: 990px) 65vw, 100vw',
                alt: section.settings.image.alt | default: shop.name | escape
            }}
          </div>
          {%- if section.settings.image_link != blank -%}
            </a>
          {%- endif -%}
        {%- else -%}
          {%- liquid
            # Görsel seçilmediyse: ürünlerin ana görselleri otomatik slayt olur
            assign slide_collection = section.settings.slide_collection
            if slide_collection == blank
              assign slide_collection = collections['all']
            endif
            assign slide_products = slide_collection.products | sort: 'created_at' | reverse
            assign slide_limit = section.settings.slide_count | default: 5
            assign has_slides = false
            for product in slide_products limit: slide_limit
              if product.featured_image
                assign has_slides = true
                break
              endif
            endfor
          -%}
          {%- if has_slides -%}
            <div
              class="editorial-hero__slider"
              id="HeroSlides-{{ section.id }}"
              data-speed="{{ section.settings.slide_speed | default: 4000 }}"
            >
              {%- assign shown = 0 -%}
              {%- for product in slide_products -%}
                {%- if shown >= slide_limit -%}{%- break -%}{%- endif -%}
                {%- if product.featured_image -%}
                  {%- assign shown = shown | plus: 1 -%}
                  {%- liquid
                    assign slide_loading = 'lazy'
                    if shown == 1
                      assign slide_loading = 'eager'
                    endif
                  -%}
                  <a
                    href="{{ product.url }}"
                    class="editorial-hero__slide{% if shown == 1 %} is-active{% endif %}"
                    aria-hidden="{% if shown == 1 %}false{% else %}true{% endif %}"
                    {% if shown > 1 %}tabindex="-1"{% endif %}
                  >
                    {{
                      product.featured_image
                      | image_url: width: 1500
                      | image_tag:
                        loading: slide_loading,
                        widths: '600, 900, 1200, 1500',
                        sizes: '(min-width: 990px) 45rem, 100vw',
                        alt: product.title | escape
                    }}
                  </a>
                {%- endif -%}
              {%- endfor -%}
            </div>
            <script>
              (function () {
                var slider = document.getElementById('HeroSlides-{{ section.id }}');
                if (!slider) return;
                var slides = slider.querySelectorAll('.editorial-hero__slide');
                if (slides.length < 2) return;
                if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
                var speed = parseInt(slider.dataset.speed, 10) || 4000;
                var current = 0;
                setInterval(function () {
                  slides[current].classList.remove('is-active');
                  slides[current].setAttribute('aria-hidden', 'true');
                  slides[current].setAttribute('tabindex', '-1');
                  current = (current + 1) % slides.length;
                  slides[current].classList.add('is-active');
                  slides[current].setAttribute('aria-hidden', 'false');
                  slides[current].removeAttribute('tabindex');
                }, speed);
              })();
            </script>
          {%- else -%}
          <div class="editorial-hero__image-wrap editorial-hero__image-wrap--fallback">
            <div class="editorial-hero__fallback">
              <img
                class="editorial-hero__fallback-symbol"
                src="{{ 'nonewear-e-logo.png' | asset_url }}"
                alt=""
                width="120"
                height="120"
                loading="eager"
              >
              <img
                class="editorial-hero__fallback-wordmark editorial-hero__fallback-wordmark--light"
                src="{{ 'nonewear-wordmark-black.png' | asset_url }}"
                alt="None Wear"
                width="360"
                height="50"
                loading="eager"
              >
              <img
                class="editorial-hero__fallback-wordmark editorial-hero__fallback-wordmark--dark"
                src="{{ 'nonewear-wordmark-white.png' | asset_url }}"
                alt="None Wear"
                width="360"
                height="50"
                loading="eager"
              >
              <p>{{ section.settings.brand_statement | escape }}</p>
            </div>
          </div>
          {%- endif -%}
        {%- endif -%}

        {%- if section.settings.vertical_label != blank -%}
          <div class="editorial-hero__vertical-label">{{ section.settings.vertical_label | escape }}</div>
        {%- endif -%}
        {%- if section.settings.season_label != blank -%}
          <div class="editorial-hero__season editorial-meta">{{ section.settings.season_label | escape }}</div>
        {%- endif -%}
        {%- if section.settings.view_link_label != blank and section.settings.view_link != blank -%}
          <div class="editorial-hero__view">
            <a class="editorial-link" href="{{ section.settings.view_link }}">{{ section.settings.view_link_label | escape }}</a>
          </div>
        {%- endif -%}
      </div>

      <div class="editorial-hero__notes">
        {%- for block in section.blocks -%}
          <article class="editorial-hero__note" {{ block.shopify_attributes }}>
            <div>
              {%- if block.settings.label != blank -%}
                <div class="editorial-meta">{{ block.settings.label | escape }}</div>
              {%- endif -%}
              {%- if block.settings.heading != blank -%}
                <h2 class="editorial-hero__note-heading">{{ block.settings.heading | escape }}</h2>
              {%- endif -%}
            </div>
            <div>
              {%- if block.settings.body != blank -%}
                <div class="editorial-hero__note-body rte">{{ block.settings.body }}</div>
              {%- endif -%}
              {%- if block.settings.link_label != blank and block.settings.link != blank -%}
                <div class="editorial-hero__note-link">
                  <a class="editorial-link" href="{{ block.settings.link }}">{{ block.settings.link_label | escape }}</a>
                </div>
              {%- endif -%}
            </div>
          </article>
        {%- endfor -%}

        {%- if section.blocks.size < 4 -%}
          {%- for i in (section.blocks.size..3) -%}
            <div class="editorial-hero__note--empty"></div>
          {%- endfor -%}
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Editorial hero",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Hero image"
    },
    {
      "type": "url",
      "id": "image_link",
      "label": "Hero image link"
    },
    {
      "type": "text",
      "id": "vertical_label",
      "label": "Vertical label",
      "default": "New arrivals"
    },
    {
      "type": "text",
      "id": "season_label",
      "label": "Bottom-left label",
      "default": "Spring Summer"
    },
    {
      "type": "text",
      "id": "view_link_label",
      "label": "Bottom-right link label",
      "default": "View more"
    },
    {
      "type": "url",
      "id": "view_link",
      "label": "Bottom-right link"
    },
    {
      "type": "text",
      "id": "brand_statement",
      "label": "Fallback brand statement",
      "default": "Kural yok. Sistem dışı. Giy ve kaybol."
    },
    {
      "type": "range",
      "id": "hero_height",
      "min": 240,
      "max": 920,
      "step": 20,
      "unit": "px",
      "label": "Hero height",
      "default": 400
    },
    {
      "type": "header",
      "content": "Ürün slaytı (görsel seçilmediğinde)"
    },
    {
      "type": "collection",
      "id": "slide_collection",
      "label": "Slayt koleksiyonu",
      "info": "Boş bırakılırsa tüm ürünler kullanılır. Ürünlerin ana görselleri slayt olarak döner."
    },
    {
      "type": "range",
      "id": "slide_count",
      "min": 2,
      "max": 8,
      "step": 1,
      "label": "Slayt sayısı",
      "default": 5
    },
    {
      "type": "range",
      "id": "slide_speed",
      "min": 2500,
      "max": 8000,
      "step": 500,
      "unit": "ms",
      "label": "Geçiş hızı",
      "default": 4000
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 0
    }
  ],
  "blocks": [
    {
      "type": "note",
      "name": "Editorial note",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Neighborhood"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Quiet streetwear essentials"
        },
        {
          "type": "richtext",
          "id": "body",
          "label": "Body",
          "default": "<p>Use these note blocks to place restrained editorial copy, category labels, or collection notes.</p>"
        },
        {
          "type": "text",
          "id": "link_label",
          "label": "Link label"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [
    {
      "name": "Editorial hero",
      "blocks": [
        {
          "type": "note"
        },
        {
          "type": "note",
          "settings": {
            "label": "Catalogue",
            "heading": "Strict, sparse, aligned",
            "body": "<p>Large blank cells are intentional. Use them to keep the homepage calm and product-first.</p>"
          }
        },
        {
          "type": "note",
          "settings": {
            "label": "Featured",
            "heading": "One third (kids)",
            "body": "<p>Reserve one cell for an alternate label, editorial note, or quiet callout.</p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}