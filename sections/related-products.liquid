{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<section class="related-products section-{{ section.id }}-padding">
  <product-recommendations
    class="page-width"
    data-url="{{ routes.product_recommendations_url }}?limit={{ section.settings.products_to_show }}"
    data-section-id="{{ section.id }}"
    data-product-id="{{ product.id }}"
  >
    {% if recommendations.performed and recommendations.products_count > 0 %}
      <h2 class="related-products__heading">{{ section.settings.heading | escape }}</h2>
      <div class="editorial-grid editorial-grid--products" style="--editorial-columns-desktop: {{ section.settings.columns_desktop }};">
        {% for recommendation in recommendations.products %}
          {% render 'product-card-minimal',
            card_product: recommendation,
            show_vendor: section.settings.show_vendor,
            show_product_type: section.settings.show_product_type,
            show_secondary_image: section.settings.show_secondary_image,
            lazy_load: true,
            media_ratio: '4 / 5'
          %}
        {% endfor %}
      </div>
    {% endif %}
  </product-recommendations>
</section>

{% schema %}
{
  "name": "Related products",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Related items"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 2,
      "max": 10,
      "step": 1,
      "label": "Products to show",
      "default": 6
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 2,
      "max": 6,
      "step": 1,
      "label": "Desktop columns",
      "default": 6
    },
    {
      "type": "checkbox",
      "id": "show_vendor",
      "label": "Show vendor",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_product_type",
      "label": "Show product type when vendor is hidden",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_secondary_image",
      "label": "Show secondary image on hover",
      "default": false
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 0
    }
  ]
}
{% endschema %}
