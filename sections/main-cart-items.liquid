{{ 'component-cart.css' | asset_url | stylesheet_tag }}
{{ 'component-cart-items.css' | asset_url | stylesheet_tag }}
{{ 'component-totals.css' | asset_url | stylesheet_tag }}
{{ 'component-price.css' | asset_url | stylesheet_tag }}
{{ 'component-discounts.css' | asset_url | stylesheet_tag }}

{%- unless settings.cart_type == 'drawer' -%}
  <script src="{{ 'cart.js' | asset_url }}" defer="defer"></script>
{%- endunless -%}

<cart-items class="{% if cart == empty %}is-empty{% endif %}">
  <div class="nw-cart page-width">

    {%- comment %} Boş sepet {%- endcomment %}
    <div class="nw-cart__empty">
      <p>{{ 'sections.cart.empty' | t }}</p>
      <a href="{{ routes.all_products_collection_url }}" class="nw-cart__continue">{{ 'general.continue_shopping' | t }}</a>
      {%- if shop.customer_accounts_enabled and customer == null -%}
        <p class="nw-cart__login-hint">
          {{ 'sections.cart.login.paragraph_html' | t: link: routes.account_login_url }}
        </p>
      {%- endif -%}
    </div>

    <form action="{{ routes.cart_url }}" class="nw-cart__form" method="post" id="cart">
      <div id="main-cart-items" data-id="{{ section.id }}">
        <div class="js-contents">

          {%- comment %} Sütun başlıkları — sadece desktop {%- endcomment %}
          <div class="nw-cart__head">
            <span class="nw-cart__head-product">{{ 'sections.cart.headings.product' | t }}</span>
            <span class="nw-cart__head-qty">{{ 'sections.cart.headings.quantity' | t }}</span>
            <span class="nw-cart__head-total">{{ 'sections.cart.headings.total' | t }}</span>
          </div>

          {%- for item in cart.items -%}
            {%- liquid
              assign has_qty_rules = false
              if item.variant.quantity_rule.increment > 1 or item.variant.quantity_rule.min > 1 or item.variant.quantity_rule.max != null
                assign has_qty_rules = true
              endif
            -%}
            <div class="nw-cart__item" id="CartItem-{{ item.index | plus: 1 }}">

              {%- comment %} Görsel {%- endcomment %}
              <div class="nw-cart__item-img">
                {%- if item.image -%}
                  <a href="{{ item.url }}" tabindex="-1">
                    <img
                      src="{{ item.image | image_url: width: 200 }}"
                      alt="{{ item.image.alt | escape }}"
                      width="100"
                      height="{{ 100 | divided_by: item.image.aspect_ratio | ceil }}"
                      loading="lazy"
                    >
                  </a>
                {%- endif -%}
              </div>

              {%- comment %} Detaylar {%- endcomment %}
              <div class="nw-cart__item-details">
                <a class="nw-cart__item-name" href="{{ item.url }}">{{ item.product.title | escape }}</a>

                {%- unless item.product.has_only_default_variant -%}
                  <div class="nw-cart__item-variants">
                    {%- for option in item.options_with_values -%}
                      <span>{{ option.name }}: {{ option.value }}</span>
                    {%- endfor -%}
                  </div>
                {%- endunless -%}

                <div class="nw-cart__item-price">
                  {%- if item.original_price != item.final_price -%}
                    <s>{{ item.original_price | money }}</s>
                    <span class="nw-cart__sale">{{ item.final_price | money }}</span>
                  {%- else -%}
                    <span>{{ item.original_price | money }}</span>
                  {%- endif -%}
                </div>
              </div>

              {%- comment %} Adet kontrolü {%- endcomment %}
              <div class="nw-cart__item-qty">
                <quantity-input class="nw-qty-ctrl">
                  {%- assign can_update = item.instructions.can_update_quantity | default: true -%}
                  <button class="nw-qty-ctrl__btn" name="minus" type="button" {% unless can_update %}disabled{% endunless %} aria-label="Azalt">−</button>
                  <input
                    class="nw-qty-ctrl__input"
                    type="number"
                    name="updates[]"
                    id="Quantity-{{ item.index | plus: 1 }}"
                    value="{{ item.quantity }}"
                    min="0"
                    data-min="{{ item.variant.quantity_rule.min }}"
                    {% if item.variant.quantity_rule.max != null %}max="{{ item.variant.quantity_rule.max }}"{% endif %}
                    step="{{ item.variant.quantity_rule.increment }}"
                    data-cart-quantity="{{ cart | item_count_for_variant: item.variant.id }}"
                    data-quantity-variant-id="{{ item.variant.id }}"
                    data-index="{{ item.index | plus: 1 }}"
                    aria-label="{{ item.product.title | escape }} adet"
                    {% unless can_update %}disabled{% endunless %}
                  >
                  <button class="nw-qty-ctrl__btn" name="plus" type="button" {% unless can_update %}disabled{% endunless %} aria-label="Artır">+</button>
                </quantity-input>
                <div class="nw-cart__item-error" id="Line-item-error-{{ item.index | plus: 1 }}" role="alert">
                  <small class="cart-item__error-text"></small>
                </div>
              </div>

              {%- comment %} Satır toplamı + Kaldır {%- endcomment %}
              <div class="nw-cart__item-total">
                {%- render 'loading-spinner' -%}
                <div class="nw-cart__item-total-price">
                  {%- if item.original_line_price != item.final_line_price -%}
                    <s>{{ item.original_line_price | money }}</s>
                    <span class="nw-cart__sale">{{ item.final_line_price | money }}</span>
                  {%- else -%}
                    <span>{{ item.original_line_price | money }}</span>
                  {%- endif -%}
                </div>
                <cart-remove-button id="Remove-{{ item.index | plus: 1 }}" data-index="{{ item.index | plus: 1 }}">
                  <button
                    type="button"
                    class="nw-cart__remove"
                    aria-label="{{ 'sections.cart.remove_title' | t: title: item.title | escape }}"
                  >✕</button>
                </cart-remove-button>
              </div>

            </div>
          {%- endfor -%}

        </div>
      </div>

      <p class="visually-hidden" id="cart-live-region-text" aria-live="polite" role="status"></p>
      <p class="visually-hidden" id="shopping-cart-line-item-status" aria-live="polite" aria-hidden="true" role="status">
        {{ 'accessibility.loading' | t }}
      </p>
    </form>

  </div>
</cart-items>

{% schema %}
{
  "name": "t:sections.main-cart-items.name",
  "settings": [
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 36
    }
  ]
}
{% endschema %}
