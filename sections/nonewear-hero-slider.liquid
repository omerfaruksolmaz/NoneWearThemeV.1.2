{% comment %}
  NONEWEAR HERO SLIDER
  - Tam ekran slayt gösterisi
  - Tıklanınca ürünler alanına scroll
  - NEIGHBORHOOD.JP ilhamı
{% endcomment %}

{%- liquid
  assign slide_count = section.blocks | where: 'type', 'slide' | size
  assign auto_rotate = section.settings.auto_rotate
  assign rotate_speed = section.settings.rotate_speed | default: 5000
  assign products_section_id = section.settings.products_section_id | default: 'products'
-%}

<div
  class="nbhd-hero shopify-section"
  id="HeroSlider-{{ section.id }}"
  data-auto-rotate="{{ auto_rotate }}"
  data-rotate-speed="{{ rotate_speed }}"
  data-products-target="{{ products_section_id }}"
  aria-label="Hero slider"
>

  {%- comment %} SLIDE TRACK {%- endcomment %}
  <div class="nbhd-hero__track" id="HeroTrack-{{ section.id }}">
    {%- if section.blocks.size > 0 -%}
      {%- for block in section.blocks -%}
        {%- if block.type == 'slide' -%}
          <div
            class="nbhd-hero__slide{% if forloop.first %} is-active{% endif %}"
            {{ block.shopify_attributes }}
          >
            {%- if block.settings.image != blank -%}
              {%- assign slide_loading = 'lazy' -%}
            {%- if forloop.first -%}{%- assign slide_loading = 'eager' -%}{%- endif -%}
            {{
                block.settings.image
                | image_url: width: 3840
                | image_tag:
                  class: 'nbhd-hero__img',
                  loading: slide_loading,
                  widths: '750, 1100, 1500, 2000, 2800, 3840',
                  sizes: '100vw',
                  alt: block.settings.label | default: shop.name | escape
              }}
            {%- else -%}
              <div class="nbhd-hero__placeholder"></div>
            {%- endif -%}

            {%- if block.settings.label != blank -%}
              <span class="nbhd-hero__overlay-label">{{ block.settings.label | escape }}</span>
            {%- endif -%}

            {%- if block.settings.season_text != blank -%}
              <span class="nbhd-hero__season">{{ block.settings.season_text | escape }}</span>
            {%- endif -%}
          </div>
        {%- endif -%}
      {%- endfor -%}
    {%- else -%}
      {%- comment %} Placeholder slide {%- endcomment %}
      <div class="nbhd-hero__slide is-active">
        <div class="nbhd-hero__placeholder">
          {{ 'hero-apparel-1' | placeholder_svg_tag: 'placeholder-svg' }}
        </div>
      </div>
    {%- endif -%}
  </div>

  {%- comment %} SCROLL HINT {%- endcomment %}
  {%- if section.settings.show_scroll_hint -%}
    <div class="nbhd-hero__scroll-hint" role="button" aria-label="Ürünlere git" tabindex="0">
      <span class="nbhd-hero__scroll-hint-text">SCROLL</span>
      <span class="nbhd-hero__scroll-hint-line"></span>
    </div>
  {%- endif -%}

  {%- comment %} DOTS {%- endcomment %}
  {%- if slide_count > 1 -%}
    <div class="nbhd-hero__dots" role="tablist" aria-label="Slaytlar">
      {%- for block in section.blocks -%}
        {%- if block.type == 'slide' -%}
          <button
            class="nbhd-hero__dot{% if forloop.first %} is-active{% endif %}"
            role="tab"
            aria-selected="{{ forloop.first }}"
            aria-label="Slayt {{ forloop.index }}"
            data-slide="{{ forloop.index0 }}"
          ></button>
        {%- endif -%}
      {%- endfor -%}
    </div>
  {%- endif -%}

</div>

<script>
(function() {
  const hero = document.getElementById('HeroSlider-{{ section.id }}');
  if (!hero) return;

  const track = hero.querySelector('.nbhd-hero__track');
  const slides = hero.querySelectorAll('.nbhd-hero__slide');
  const dots = hero.querySelectorAll('.nbhd-hero__dot');
  const scrollHint = hero.querySelector('.nbhd-hero__scroll-hint');
  const autoRotate = hero.dataset.autoRotate === 'true';
  const rotateSpeed = parseInt(hero.dataset.rotateSpeed) || 5000;
  const productsTarget = hero.dataset.productsTarget;
  const total = slides.length;

  if (total === 0) return;

  let current = 0;
  let timer = null;
  let isScrolling = false;

  function goTo(idx) {
    current = (idx + total) % total;
    track.style.transform = `translateX(-${current * 100}%)`;
    dots.forEach((d, i) => {
      d.classList.toggle('is-active', i === current);
      d.setAttribute('aria-selected', i === current ? 'true' : 'false');
    });
  }

  function scrollToProducts() {
    if (isScrolling) return;
    isScrolling = true;

    let target = null;

    // productsTarget ID ile ara
    if (productsTarget) {
      target = document.getElementById(productsTarget);
    }

    // Sayfadaki ürün grid'ini bul
    if (!target) {
      target = document.querySelector(
        '.editorial-products, .editorial-collection-grid, #products, [data-section-type="featured-collection"], .featured-collection, .main-collection-product-grid'
      );
    }

    // Bulamazsan hero'nun yüksekliği kadar scroll et
    if (!target) {
      window.scrollTo({ top: hero.offsetHeight, behavior: 'smooth' });
    } else {
      const headerHeight = parseInt(getComputedStyle(document.documentElement).getPropertyValue('--header-height') || '0');
      const targetTop = target.getBoundingClientRect().top + window.pageYOffset - headerHeight - 1;
      window.scrollTo({ top: targetTop, behavior: 'smooth' });
    }

    setTimeout(() => { isScrolling = false; }, 1000);
  }

  // Click = scroll to products
  hero.addEventListener('click', (e) => {
    if (e.target.classList.contains('nbhd-hero__dot')) return;
    scrollToProducts();
  });

  if (scrollHint) {
    scrollHint.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' || e.key === ' ') {
        e.preventDefault();
        scrollToProducts();
      }
    });
  }

  // Dot navigation
  dots.forEach((dot) => {
    dot.addEventListener('click', (e) => {
      e.stopPropagation();
      clearTimeout(timer);
      goTo(parseInt(dot.dataset.slide));
      if (autoRotate) startTimer();
    });
  });

  // Auto rotate (hareket azaltma tercihi varsa devre dışı)
  function startTimer() {
    clearTimeout(timer);
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
    if (total > 1) {
      timer = setTimeout(() => {
        goTo(current + 1);
        startTimer();
      }, rotateSpeed);
    }
  }

  // Touch / swipe
  let touchStartX = 0;
  let touchMoved = false;

  hero.addEventListener('touchstart', (e) => {
    touchStartX = e.touches[0].clientX;
    touchMoved = false;
  }, { passive: true });

  hero.addEventListener('touchmove', () => {
    touchMoved = true;
  }, { passive: true });

  hero.addEventListener('touchend', (e) => {
    if (!touchMoved) return;
    const dx = touchStartX - e.changedTouches[0].clientX;
    if (Math.abs(dx) > 40) {
      clearTimeout(timer);
      goTo(current + (dx > 0 ? 1 : -1));
      if (autoRotate) startTimer();
    }
  }, { passive: true });

  // Start
  if (autoRotate && total > 1) startTimer();
})();
</script>

{% schema %}
{
  "name": "Hero Slider",
  "tag": "section",
  "class": "shopify-section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "checkbox",
      "id": "auto_rotate",
      "label": "Otomatik geçiş",
      "default": true
    },
    {
      "type": "range",
      "id": "rotate_speed",
      "min": 2000,
      "max": 9000,
      "step": 500,
      "unit": "ms",
      "label": "Geçiş hızı",
      "default": 5000
    },
    {
      "type": "checkbox",
      "id": "show_scroll_hint",
      "label": "Scroll ipucu göster",
      "default": true
    },
    {
      "type": "text",
      "id": "products_section_id",
      "label": "Ürün bölümü ID",
      "info": "Tıklanınca bu ID'ye scroll yapılır. Varsayılan: 'products'",
      "default": "products"
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slayt",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Görsel"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Alt etiket",
          "info": "Sol altta görünür (örn: SS26 COLLECTION)"
        },
        {
          "type": "text",
          "id": "season_text",
          "label": "Sezon yazısı",
          "info": "Sağ üstte dikey görünür (örn: SPRING / SUMMER 2026)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Hero Slider",
      "blocks": [
        { "type": "slide" },
        { "type": "slide" }
      ]
    }
  ]
}
{% endschema %}
