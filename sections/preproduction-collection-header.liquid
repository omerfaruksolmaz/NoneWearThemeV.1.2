<section class="preproduction-collection-header">
  <div class="page-width">
    <div class="preproduction-collection-header__grid">
      <div>
        <span class="preproduction-collection-header__index">{{ section.settings.index_label | escape }}</span>
        <h1 class="preproduction-collection-header__title">
          {{ collection.title | default: section.settings.heading | escape }}
        </h1>
      </div>
      <div class="preproduction-collection-header__content">
        {%- if section.settings.heading != blank -%}
          <p class="preproduction-collection-header__eyebrow">{{ section.settings.heading | escape }}</p>
        {%- endif -%}
        <div class="preproduction-collection-header__body rte">
          {%- if collection.description != blank -%}
            {{ collection.description }}
          {%- else -%}
            {{ section.settings.body }}
          {%- endif -%}
        </div>
        <dl class="preproduction-collection-header__facts">
          <div>
            <dt>Teslimat</dt>
            <dd>{{ section.settings.delivery | escape }}</dd>
          </div>
          <div>
            <dt>Sistem</dt>
            <dd>{{ section.settings.system_label | escape }}</dd>
          </div>
        </dl>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Pre-production header",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "index_label",
      "label": "Index label",
      "default": "NONE WEAR / PRE-01"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Supporting heading",
      "default": "Üretim Aşamasında"
    },
    {
      "type": "richtext",
      "id": "body",
      "label": "Default description",
      "default": "<p>İlk üretim partisine daha düşük fiyatla katıl. Bu seçkideki parçalar üretim tamamlandıktan sonra gönderilir.</p>"
    },
    {
      "type": "text",
      "id": "delivery",
      "label": "Delivery text",
      "default": "45-60 gün"
    },
    {
      "type": "text",
      "id": "system_label",
      "label": "System label",
      "default": "İlk üretim partisi"
    }
  ],
  "presets": [
    {
      "name": "Pre-production header"
    }
  ]
}
{% endschema %}
